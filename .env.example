# AeroIntel — variables de entorno (copia a .env o pásalas inline). Ninguna es obligatoria;
# sin ellas corre en modo heurístico y dry-run.

# ── Análisis con LLM (recomendado: Groq, free tier real) ──────────────────────────────
# Proveedor PRIMARIO: groq | openrouter | cerebras | anthropic
AEROINTEL_LLM=groq
GROQ_API_KEY=                 # https://console.groq.com  (gratis)
# RESPALDO AUTOMÁTICO: si el primario agota su cuota diaria (429), la IA sigue con cualquier
# otro proveedor que TENGA CLAVE aquí — mismo modelo Llama 3.3 70B en groq/openrouter, gratis.
# Añadir OPENROUTER_API_KEY es la forma más simple de que el carrusel/top NUNCA queden en
# heurística por un tope de cuota (OpenRouter: https://openrouter.ai/keys — gratis, 2 min).
# OPENROUTER_API_KEY=
# CEREBRAS_API_KEY=            # https://cloud.cerebras.ai  (gratis)
# ANTHROPIC_API_KEY=
# AEROINTEL_MODEL=llama-3.3-70b-versatile
AEROINTEL_LLM_MAX=24         # cuántos eventos top analiza el LLM (resto: heurística)
AEROINTEL_LLM_SLEEP=1.2      # pausa entre llamadas (respeta rate limits del free tier)

# ── Distribución a Mattermost (opcional) ──────────────────────────────────────────────
# MATTERMOST_WEBHOOK_URL=https://<mattermost>/hooks/<token>

# ── NOTAMs de la estación (opcional) — SkyLink API vía RapidAPI ───────────────────────
# Sin clave NO se muestra la sección NOTAM (degradación elegante). NUNCA llega al navegador.
# RAPIDAPI_KEY=                 # https://rapidapi.com → suscríbete a "SkyLink API"
AEROINTEL_NOTAM_ICAO=MDPC      # ICAO de la estación (MDPC = Punta Cana / PUJ)
# AEROINTEL_NOTAM_DEMO=1       # muestra NOTAMs de ejemplo (para previsualizar sin clave/suscripción)

# ── Tuning del pipeline ───────────────────────────────────────────────────────────────
AEROINTEL_WHEN=7d            # ventana de Google News (recencia)
AEROINTEL_MAX_AGE_H=168      # descarta noticias más viejas que N horas
AEROINTEL_MIN_SCORE=30       # umbral de relevancia para publicar
AEROINTEL_IMG_N=24           # cuántas notas top enriquecen con imagen
# AEROINTEL_NO_IMG=1         # desactiva la extracción de imágenes (más rápido)
